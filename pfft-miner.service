[Unit]
Description=PFFT CUDA Miner
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=%i
WorkingDirectory=/home/%i/pfft-miner-cuda
ExecStart=/usr/bin/python3 /home/%i/pfft-miner-cuda/pfft_miner.py
Restart=on-failure
RestartSec=30
Environment="PATH=/usr/local/cuda/bin:/usr/bin:/bin"
Environment="LD_LIBRARY_PATH=/usr/local/cuda/lib64"

[Install]
WantedBy=multi-user.target
